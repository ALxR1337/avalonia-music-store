<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Lucide-style line icons (24×24 viewBox, designed for stroke=1.5, round caps/joins).
        Render with: <Path Classes="icon" Data="{StaticResource IconX}"/> from ControlStyles.axaml.
        Filled variants render with `Classes="icon filled"` (Fill instead of Stroke).
    -->

    <!-- Navigation -->
    <StreamGeometry x:Key="IconHome">M3 9.5 L12 3 L21 9.5 V20 a1 1 0 0 1 -1 1 H15 V14 H9 V21 H4 a1 1 0 0 1 -1 -1 Z</StreamGeometry>
    <StreamGeometry x:Key="IconCart">M3 4 H5 L7.4 15.6 a2 2 0 0 0 2 1.6 H17 a2 2 0 0 0 2 -1.6 L20.5 8 H6 M9 21 a1 1 0 1 1 -2 0 a1 1 0 0 1 2 0 Z M19 21 a1 1 0 1 1 -2 0 a1 1 0 0 1 2 0 Z</StreamGeometry>
    <StreamGeometry x:Key="IconBox">M3 7 L12 3 L21 7 V17 L12 21 L3 17 Z M3 7 L12 11 L21 7 M12 11 V21</StreamGeometry>
    <StreamGeometry x:Key="IconUser">M12 12 a4 4 0 1 0 0 -8 a4 4 0 0 0 0 8 Z M4 21 V19 a4 4 0 0 1 4 -4 H16 a4 4 0 0 1 4 4 V21</StreamGeometry>
    <StreamGeometry x:Key="IconHeadphones">M3 18 V12 a9 9 0 0 1 18 0 V18 M3 14 H7 V21 H4 a1 1 0 0 1 -1 -1 Z M21 14 H17 V21 H20 a1 1 0 0 1 1 -1 Z</StreamGeometry>
    <StreamGeometry x:Key="IconSettings">M12 15 a3 3 0 1 0 0 -6 a3 3 0 0 0 0 6 Z M19.4 15 a1.65 1.65 0 0 0 0.33 1.82 l0.06 0.06 a2 2 0 1 1 -2.83 2.83 l-0.06 -0.06 a1.65 1.65 0 0 0 -1.82 -0.33 a1.65 1.65 0 0 0 -1 1.51 V21 a2 2 0 0 1 -4 0 v-0.09 a1.65 1.65 0 0 0 -1 -1.51 a1.65 1.65 0 0 0 -1.82 0.33 l-0.06 0.06 a2 2 0 1 1 -2.83 -2.83 l0.06 -0.06 a1.65 1.65 0 0 0 0.33 -1.82 a1.65 1.65 0 0 0 -1.51 -1 H3 a2 2 0 0 1 0 -4 h0.09 a1.65 1.65 0 0 0 1.51 -1 a1.65 1.65 0 0 0 -0.33 -1.82 l-0.06 -0.06 a2 2 0 1 1 2.83 -2.83 l0.06 0.06 a1.65 1.65 0 0 0 1.82 0.33 H9 a1.65 1.65 0 0 0 1 -1.51 V3 a2 2 0 0 1 4 0 v0.09 a1.65 1.65 0 0 0 1 1.51 a1.65 1.65 0 0 0 1.82 -0.33 l0.06 -0.06 a2 2 0 1 1 2.83 2.83 l-0.06 0.06 a1.65 1.65 0 0 0 -0.33 1.82 V9 a1.65 1.65 0 0 0 1.51 1 H21 a2 2 0 0 1 0 4 h-0.09 a1.65 1.65 0 0 0 -1.51 1 Z</StreamGeometry>

    <!-- Search / Filter -->
    <StreamGeometry x:Key="IconSearch">M11 4 a7 7 0 1 0 0 14 a7 7 0 0 0 0 -14 Z M21 21 L16.65 16.65</StreamGeometry>
    <StreamGeometry x:Key="IconFilter">M22 3 H2 L10 12.46 V19 L14 21 V12.46 L22 3 Z</StreamGeometry>

    <!-- Transport -->
    <!-- Phantom M1 4 centers centroid horizontally; +3 y-shift on the triangle
         compensates Avalonia's stretch-rendering bias so it sits at the circle center. -->
    <StreamGeometry x:Key="IconPlay">M1 4 M6 5.5 L20 13.5 L6 21.5 Z</StreamGeometry>
    <StreamGeometry x:Key="IconPause">M6 4 H10 V20 H6 Z M14 4 H18 V20 H14 Z</StreamGeometry>
    <StreamGeometry x:Key="IconSkipBack">M19 20 L9 12 L19 4 Z M5 19 V5</StreamGeometry>
    <StreamGeometry x:Key="IconSkipForward">M5 4 L15 12 L5 20 Z M19 5 V19</StreamGeometry>
    <StreamGeometry x:Key="IconVolume">M11 5 L6 9 H3 V15 H6 L11 19 Z M15.5 8.5 a5 5 0 0 1 0 7 M18.5 5.5 a9 9 0 0 1 0 13</StreamGeometry>

    <!-- Status / Mark -->
    <StreamGeometry x:Key="IconHeart">M20.84 4.61 a5.5 5.5 0 0 0 -7.78 0 L12 5.67 L10.94 4.61 a5.5 5.5 0 0 0 -7.78 7.78 L12 21.23 L20.84 12.39 a5.5 5.5 0 0 0 0 -7.78 Z</StreamGeometry>
    <StreamGeometry x:Key="IconHeartFilled">M20.84 4.61 a5.5 5.5 0 0 0 -7.78 0 L12 5.67 L10.94 4.61 a5.5 5.5 0 0 0 -7.78 7.78 L12 21.23 L20.84 12.39 a5.5 5.5 0 0 0 0 -7.78 Z</StreamGeometry>
    <StreamGeometry x:Key="IconStar">M12 3 L14.85 8.78 L21.23 9.72 L16.61 14.21 L17.7 20.56 L12 17.56 L6.3 20.56 L7.39 14.21 L2.77 9.72 L9.15 8.78 Z</StreamGeometry>

    <!-- Player controls -->
    <StreamGeometry x:Key="IconShuffle">M16 3 h5 v5 M4 20 L21 3 M21 16 v5 h-5 M15 15 l6 6 M4 4 l5 5</StreamGeometry>
    <StreamGeometry x:Key="IconRepeat">M17 1 l4 4 -4 4 M3 11 V9 a4 4 0 0 1 4 -4 h14 M7 23 l-4 -4 4 -4 M21 13 v2 a4 4 0 0 1 -4 4 H3</StreamGeometry>
    <StreamGeometry x:Key="IconRepeatOne">M17 1 l4 4 -4 4 M3 11 V9 a4 4 0 0 1 4 -4 h14 M7 23 l-4 -4 4 -4 M21 13 v2 a4 4 0 0 1 -4 4 H3 M11 15 V10 l-2 1</StreamGeometry>

    <!-- Actions -->
    <StreamGeometry x:Key="IconEdit">M12 20 H21 M16.5 3.5 a2.121 2.121 0 0 1 3 3 L7 19 L3 21 L5 17 Z</StreamGeometry>
    <StreamGeometry x:Key="IconTrash">M3 6 H21 M19 6 V20 a2 2 0 0 1 -2 2 H7 a2 2 0 0 1 -2 -2 V6 M8 6 V4 a2 2 0 0 1 2 -2 H14 a2 2 0 0 1 2 2 V6 M10 11 V17 M14 11 V17</StreamGeometry>
    <StreamGeometry x:Key="IconSave">M19 21 H5 a2 2 0 0 1 -2 -2 V5 a2 2 0 0 1 2 -2 H16 L21 8 V19 a2 2 0 0 1 -2 2 Z M17 21 V13 H7 V21 M7 3 V8 H15</StreamGeometry>
    <StreamGeometry x:Key="IconClose">M18 6 L6 18 M6 6 L18 18</StreamGeometry>
    <StreamGeometry x:Key="IconCheck">M20 6 L9 17 L4 12</StreamGeometry>
    <!-- Phantom M4 4 / M20 20 force a 16×16 bbox so Stretch=Uniform preserves the
         Lucide-style padding around the 6×12 chevron arms. -->
    <StreamGeometry x:Key="IconChevronLeft">M4 4 M20 20 M15 18 L9 12 L15 6</StreamGeometry>
    <StreamGeometry x:Key="IconChevronRight">M4 4 M20 20 M9 18 L15 12 L9 6</StreamGeometry>
    <StreamGeometry x:Key="IconChevronDown">M4 4 M20 20 M6 9 L12 15 L18 9</StreamGeometry>
    <StreamGeometry x:Key="IconMaximize">M3 8 V3 H8 M21 8 V3 H16 M3 16 V21 H8 M21 16 V21 H16</StreamGeometry>
    <StreamGeometry x:Key="IconMinus">M5 5 M19 19 M5 12 H19</StreamGeometry>
    <StreamGeometry x:Key="IconPlus">M12 5 V19 M5 12 H19</StreamGeometry>

    <!-- Account menu -->
    <StreamGeometry x:Key="IconKey">M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 0 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z</StreamGeometry>
    <StreamGeometry x:Key="IconLogout">M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9</StreamGeometry>
    <StreamGeometry x:Key="IconLogin">M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4 M10 17l5-5-5-5 M15 12H3</StreamGeometry>

    <!-- Format toggle -->
    <StreamGeometry x:Key="IconCircle">M12 22 a10 10 0 1 0 0 -20 a10 10 0 0 0 0 20 Z</StreamGeometry>
    <StreamGeometry x:Key="IconCircleFilled">M12 22 a10 10 0 1 0 0 -20 a10 10 0 0 0 0 20 Z</StreamGeometry>

</ResourceDictionary>
