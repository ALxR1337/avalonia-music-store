<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MusicApp.ViewModels"
        xmlns:views="using:MusicApp.Views"
        xmlns:conv="using:MusicApp.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="MusicApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Музичний магазин"
        Icon="avares://MusicApp/Assets/app-icon.png"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="640"
        Background="{StaticResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowDecorations="BorderOnly"
        TransparencyLevelHint="None">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="48,*,Auto" ColumnDefinitions="Auto,*"
          SizeChanged="OnRootSizeChanged">

        <!-- ============ TITLE BAR ============ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource BgSidebarBrush}"
                PointerPressed="OnTitleBarPressed">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                <!-- Global back/forward -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Spacing="8" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Button Classes="icon-pill"
                            Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding CanGoBack}">
                        <Path Classes="icon sm primary" Data="{StaticResource IconChevronLeft}"/>
                    </Button>
                    <Button Classes="icon-pill"
                            Command="{Binding GoForwardCommand}"
                            IsEnabled="{Binding CanGoForward}">
                        <Path Classes="icon sm primary" Data="{StaticResource IconChevronRight}"/>
                    </Button>
                </StackPanel>

                <!-- Centered search + autocomplete popup -->
                <Border Grid.Column="1" Classes="search-pill"
                        Padding="14,0" MaxWidth="520" Height="40"
                        HorizontalAlignment="Stretch" Margin="20,0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Path Grid.Column="0" Classes="icon sm primary"
                              Data="{StaticResource IconSearch}"
                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1" Classes="bare"
                                 MinHeight="0"
                                 PlaceholderText="Виконавці, альбоми, треки..."
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OnSearchKeyDown"
                                 GotFocus="OnSearchGotFocus"/>
                        <!-- Click-handler only (no Command) so code-behind can
                             return focus to the box after clearing. -->
                        <Button Grid.Column="2" Classes="ghost" Padding="4"
                                VerticalAlignment="Center" Margin="6,0,0,0"
                                IsVisible="{Binding SearchQuery, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Click="OnSearchClear"
                                AutomationProperties.Name="Очистити пошук">
                            <Path Classes="icon sm" Data="{StaticResource IconClose}"/>
                        </Button>
                        <Popup Grid.Column="1"
                               PlacementTarget="{Binding $parent[Border]}"
                               Placement="Bottom"
                               IsOpen="{Binding IsAutocompleteOpen}"
                               IsLightDismissEnabled="True"
                               WindowManagerAddShadowHint="False">
                            <!-- Width = pill width minus 40 (its pill-end diameter at the bottom)
                                 so the popup's flat top sits inside the pill's straight bottom
                                 section and doesn't poke past the rounded ends. -->
                            <Border Width="{Binding $parent[Popup].PlacementTarget.Bounds.Width, Converter={StaticResource DoubleOffset}, ConverterParameter=-40}"
                                    Classes="search-popup"
                                    Padding="6">
                                <ItemsControl ItemsSource="{Binding Suggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:SuggestionItemViewModel">
                                            <Button Classes="ghost"
                                                    Classes.highlighted="{Binding IsHighlighted}"
                                                    HorizontalContentAlignment="Stretch"
                                                    HorizontalAlignment="Stretch"
                                                    Padding="10,6"
                                                    Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).PickSuggestionCommand}"
                                                    CommandParameter="{Binding}">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <Border Grid.Column="0" Width="32" Height="32"
                                                            Margin="0,0,10,0"
                                                            Background="{StaticResource BgChipBrush}"
                                                            CornerRadius="16"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Path Classes="icon sm primary"
                                                                  Data="{Binding Kind, Converter={StaticResource SuggestionKindToIcon}}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  IsVisible="{Binding ImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                            <Image Source="{Binding ImagePath, Converter={StaticResource CoverPathToImage}}"
                                                                   Stretch="UniformToFill"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="{Binding Text}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Subtitle}" Classes="muted" FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>

                <!-- User + window buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center" Margin="0,0,8,0">

                    <Button Classes="primary" Content="Увійти"
                            Command="{Binding OpenLoginCommand}"
                            IsVisible="{Binding IsGuest}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" Padding="14,4"/>

                    <Button x:Name="UserMenuButton" Classes="user-chip"
                            Padding="4,4,10,4" Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Command="{Binding ToggleUserMenuCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border Width="22" Height="22" CornerRadius="11"
                                    Background="{StaticResource BgChipBrush}">
                                <Grid>
                                    <Path Data="{StaticResource IconUser}"
                                          Fill="Transparent"
                                          Stroke="{StaticResource FgPrimaryBrush}"
                                          StrokeThickness="1.5"
                                          StrokeLineCap="Round" StrokeJoin="Round"
                                          Width="14" Height="14" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsVisible="{Binding IsGuest}"/>
                                    <TextBlock Text="{Binding UserDisplayName, Converter={StaticResource FirstChar}}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource FgPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding !IsGuest}"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding UserDisplayName}"
                                       Foreground="{StaticResource FgSecondaryBrush}"
                                       VerticalAlignment="Center" FontSize="13"/>
                            <Path Classes="icon sm" Data="{StaticResource IconChevronDown}"
                                  VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Account menu — inline Popup (its content inherits the window
                         DataContext, so the row Commands resolve against the VM, which
                         a Button.Flyout does not reliably do). -->
                    <Popup PlacementTarget="{Binding #UserMenuButton}"
                           Placement="BottomEdgeAlignedRight"
                           HorizontalOffset="0" VerticalOffset="6"
                           IsOpen="{Binding IsUserMenuOpen, Mode=TwoWay}"
                           IsLightDismissEnabled="True"
                           WindowManagerAddShadowHint="False">
                        <Border Classes="app-menu" Padding="6">
                            <StackPanel MinWidth="232" Spacing="2">

                                <!-- Header (signed-in only) -->
                                <StackPanel Margin="10,8" Spacing="1"
                                            IsVisible="{Binding !IsGuest}">
                                    <TextBlock Text="{Binding UserDisplayName}"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource FgPrimaryBrush}"/>
                                    <TextBlock Text="{Binding UserEmail}"
                                               Classes="muted" FontSize="12"
                                               IsVisible="{Binding UserEmail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Text="{Binding UserRoleLabel}"
                                               Classes="muted" FontSize="11"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="{StaticResource DividerSoftBrush}"
                                           Margin="6,2" IsVisible="{Binding !IsGuest}"/>

                                <!-- Signed-in actions -->
                                <Button Classes="menu-row" IsVisible="{Binding !IsGuest}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Profile">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Path Classes="icon sm" Data="{StaticResource IconUser}"/>
                                        <TextBlock Text="Профіль" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="menu-row" IsVisible="{Binding !IsGuest}"
                                        Command="{Binding ChangePasswordCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Path Classes="icon sm" Data="{StaticResource IconKey}"/>
                                        <TextBlock Text="Змінити пароль" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Rectangle Height="1" Fill="{StaticResource DividerSoftBrush}"
                                           Margin="6,2" IsVisible="{Binding !IsGuest}"/>
                                <Button Classes="menu-row" IsVisible="{Binding !IsGuest}"
                                        Command="{Binding LogoutCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Path Classes="icon sm" Data="{StaticResource IconLogout}"/>
                                        <TextBlock Text="Вийти" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Guest actions -->
                                <Button Classes="menu-row" IsVisible="{Binding IsGuest}"
                                        Command="{Binding OpenLoginCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Path Classes="icon sm" Data="{StaticResource IconLogin}"/>
                                        <TextBlock Text="Увійти" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="menu-row" IsVisible="{Binding IsGuest}"
                                        Command="{Binding OpenRegisterCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Path Classes="icon sm" Data="{StaticResource IconEdit}"/>
                                        <TextBlock Text="Реєстрація" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Button Classes="icon" Width="36" Height="32"
                            Click="OnMinimize">
                        <Path Stroke="{StaticResource FgSecondaryBrush}"
                              StrokeThickness="1.4"
                              Data="M 0,6 L 12,6"/>
                    </Button>
                    <Button Classes="icon" Width="36" Height="32"
                            Click="OnMaximize">
                        <Path Stroke="{StaticResource FgSecondaryBrush}"
                              StrokeThickness="1.4"
                              Data="M 0.7,0.7 L 11.3,0.7 L 11.3,11.3 L 0.7,11.3 Z"/>
                    </Button>
                    <Button Classes="icon" Width="36" Height="32"
                            Click="OnClose">
                        <Path Stroke="{StaticResource FgSecondaryBrush}"
                              StrokeThickness="1.4"
                              Data="M 0.7,0.7 L 11.3,11.3 M 11.3,0.7 L 0.7,11.3"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ SIDEBAR ============ -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource BgSidebarBrush}"
                Padding="12,16"
                Width="{Binding IsSidebarCollapsed, Converter={x:Static conv:BoolToWidthConverter.Instance}, ConverterParameter=72|240}">
            <StackPanel Spacing="4">
                <TextBlock Classes="tiny" Text="МАГАЗИН" Margin="14,0,0,8"
                           IsVisible="{Binding !IsSidebarCollapsed}"/>
                <Button Classes="nav-item" Classes.active="{Binding IsCatalogActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Catalog">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Path Classes="icon" Data="{StaticResource IconHome}"/>
                        <TextBlock Text="Каталог" VerticalAlignment="Center" IsVisible="{Binding !IsSidebarCollapsed}"/>
                    </StackPanel>
                </Button>
                <Button Classes="nav-item" Classes.active="{Binding IsSearchActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="SearchResults">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Path Classes="icon" Data="{StaticResource IconSearch}"/>
                        <TextBlock Text="Пошук" VerticalAlignment="Center" IsVisible="{Binding !IsSidebarCollapsed}"/>
                    </StackPanel>
                </Button>
                <Button Classes="nav-item" Classes.active="{Binding IsCartActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Cart">
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                        <Path Grid.Column="0" Classes="icon" Data="{StaticResource IconCart}"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="Кошик" VerticalAlignment="Center"
                                   IsVisible="{Binding !IsSidebarCollapsed}"/>
                        <Border Grid.Column="2" Classes="chip accent" Padding="6,1"
                                IsVisible="{Binding HasCartItems}"
                                VerticalAlignment="Center" Margin="6,0,0,0">
                            <TextBlock Text="{Binding CartCount}" FontSize="10"
                                       Foreground="{StaticResource OnAccentBrush}" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Button>
                <Button Classes="nav-item" Classes.active="{Binding IsProfileActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Profile">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Path Classes="icon" Data="{StaticResource IconUser}"/>
                        <TextBlock Text="Профіль" VerticalAlignment="Center" IsVisible="{Binding !IsSidebarCollapsed}"/>
                    </StackPanel>
                </Button>

                <Rectangle Height="1" Fill="{StaticResource DividerSoftBrush}" Margin="10,12"/>

                <TextBlock Classes="tiny" Text="МЕДІАТЕКА" Margin="14,4,0,8"
                           IsVisible="{Binding !IsSidebarCollapsed}"/>
                <Button Classes="nav-item" Classes.active="{Binding IsPlayerActive}"
                        Command="{Binding NavigateCommand}" CommandParameter="Player">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Path Classes="icon" Data="{StaticResource IconHeadphones}"/>
                        <TextBlock Text="Плеєр" VerticalAlignment="Center" IsVisible="{Binding !IsSidebarCollapsed}"/>
                    </StackPanel>
                </Button>

                <Rectangle Height="1" Fill="{StaticResource DividerSoftBrush}" Margin="10,12"
                           IsVisible="{Binding IsAdmin}"/>
                <TextBlock Classes="tiny" Text="АДМІН" Margin="14,4,0,8">
                    <TextBlock.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsAdmin"/>
                            <Binding Path="!IsSidebarCollapsed"/>
                        </MultiBinding>
                    </TextBlock.IsVisible>
                </TextBlock>
                <Button Classes="nav-item" Classes.active="{Binding IsAdminActive}"
                        IsVisible="{Binding IsAdmin}"
                        Command="{Binding NavigateCommand}" CommandParameter="Admin">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Path Classes="icon" Data="{StaticResource IconSettings}"/>
                        <TextBlock Text="Керування" VerticalAlignment="Center" IsVisible="{Binding !IsSidebarCollapsed}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ============ CONTENT ============ -->
        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource BgBaseBrush}">
            <ScrollViewer x:Name="ContentScroll" HorizontalScrollBarVisibility="Disabled">
                <ContentControl Content="{Binding CurrentView}"/>
            </ScrollViewer>
        </Border>

        <!-- ============ MINI-PLAYER ============ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{StaticResource BgPlayerBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,1,0,0"
                Height="80"
                IsVisible="{Binding IsMiniPlayerVisible}"
                RenderTransformOrigin="0.5,0.5">
            <Border.Styles>
                <Style Selector="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="RenderTransform" Value="translateY(80px)"/>
                </Style>
                <Style Selector="Border[IsVisible=true]">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="RenderTransform" Value="translateY(0)"/>
                </Style>
            </Border.Styles>
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"/>
                </Transitions>
            </Border.Transitions>
            <views:MiniPlayerView DataContext="{Binding MiniPlayer}"/>
        </Border>

        <!-- ============ FULLSCREEN COVER OVERLAY ============
             Spans the whole window. Click on the dark backdrop closes;
             clicks on the image itself are swallowed in code-behind.
             Esc also closes via OnGlobalKeyDown. The 1*/8*/1* Grid gives the
             requested ~10% margin on each side; Viewbox scales the square
             cover Border to fit while preserving its 1:1 aspect ratio. -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#CC000000"
                IsVisible="{Binding IsCoverFullscreen}"
                ZIndex="1000"
                PointerPressed="OnCoverBackdropPressed">
            <Grid RowDefinitions="*,8*,*" ColumnDefinitions="*,8*,*">
                <!-- Visible exit: backdrop click and Esc also close, but neither
                     is discoverable for an overlay opened by an accidental click. -->
                <Button Classes="icon" Width="40" Height="40"
                        Grid.RowSpan="3" Grid.ColumnSpan="3"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,20,20,0"
                        Command="{Binding CloseCoverFullscreenCommand}"
                        ToolTip.Tip="Закрити (Esc)">
                    <Path Classes="icon" Data="{StaticResource IconClose}"/>
                </Button>
                <Viewbox Grid.Row="1" Grid.Column="1" Stretch="Uniform">
                    <Border Width="600" Height="600"
                            CornerRadius="{StaticResource RadiusL}"
                            ClipToBounds="True"
                            PointerPressed="OnCoverImagePressed"
                            Background="{Binding FullscreenCoverAlbum, Converter={StaticResource AlbumToGradient}}"
                            BoxShadow="0 24 64 0 #99000000">
                        <Grid>
                            <TextBlock Text="{Binding FullscreenCoverAlbum.Title, Converter={StaticResource FirstChar}}"
                                       FontSize="220" FontWeight="Bold" Opacity="0.45"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource FgPrimaryBrush}"
                                       IsVisible="{Binding FullscreenCoverAlbum.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                            <Image Source="{Binding FullscreenCoverAlbum.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                </Viewbox>
            </Grid>
        </Border>

        <!-- ============ LOGIN OVERLAY ============
             Spotify-style modal: a dimmed backdrop over the whole window with a
             centered login card. Backdrop click / Esc dismiss it (handled in
             code-behind); the card itself swallows presses. Sits above the cover
             overlay so login always wins focus. -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#CC000000"
                IsVisible="{Binding IsLoginVisible}"
                ZIndex="1100"
                PointerPressed="OnLoginBackdropPressed">
            <views:LoginView x:Name="LoginCard"
                             DataContext="{Binding Login}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             PointerPressed="OnLoginCardPressed"/>
        </Border>
    </Grid>
</Window>
