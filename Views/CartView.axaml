<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             x:Class="MusicApp.Views.CartView"
             x:DataType="vm:CartViewModel">

    <StackPanel Margin="32,24,32,32" Spacing="20">

        <TextBlock Classes="h1"
                   Text="{Binding ItemCount, StringFormat='Кошик ({0})'}"/>

        <!-- Flash message -->
        <Border Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusS}" Padding="12,8"
                IsVisible="{Binding FlashMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding FlashMessage}" Classes="muted"/>
        </Border>

        <!-- Guest banner -->
        <Border Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusM}" Padding="14"
                IsVisible="{Binding IsGuest}">
            <TextBlock TextWrapping="Wrap" Classes="muted">
                <Run Text="Ви переглядаєте кошик як гість. "/>
                <Run Text="Для оформлення замовлення необхідно увійти в обліковий запис." FontWeight="SemiBold" Foreground="{StaticResource FgPrimaryBrush}"/>
            </TextBlock>
        </Border>

        <!-- Empty state -->
        <Border Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusL}"
                Padding="50" IsVisible="{Binding IsEmpty}">
            <StackPanel Spacing="10" HorizontalAlignment="Center">
                <Path Classes="icon xl" Data="{StaticResource IconCart}"
                      HorizontalAlignment="Center" Opacity="0.6"/>
                <TextBlock Text="У кошику поки що порожньо" Classes="h3"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Знайдіть щось у каталозі і повертайтесь сюди"
                           Classes="muted" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Items list -->
        <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="m:CartItem">
                    <Border Background="{StaticResource BgElevatedBrush}"
                            CornerRadius="{StaticResource RadiusM}"
                            Padding="18" Margin="0,0,0,14">
                        <Grid ColumnDefinitions="76,*,Auto,Auto,Auto">
                            <Border Grid.Column="0" Width="60" Height="60"
                                    CornerRadius="{StaticResource RadiusS}"
                                    Background="{Binding Product.Album, Converter={StaticResource AlbumToGradient}}"
                                    ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="{Binding Product.Album.Title, Converter={StaticResource FirstChar}}"
                                               FontSize="28" FontWeight="Bold" Opacity="0.45"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource FgPrimaryBrush}"
                                               IsVisible="{Binding Product.Album.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                    <Image Source="{Binding Product.Album.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                           Stretch="UniformToFill"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Product.Album.Title}" FontWeight="SemiBold"/>
                                <TextBlock Classes="muted"
                                           Text="{Binding Product.Album.Artist.Name}"/>
                                <Border Classes="chip" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Product.FormatBadge}" FontSize="14"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        Spacing="10" VerticalAlignment="Center">
                                <Button Classes="icon" Width="36" Height="36"
                                        Command="{Binding $parent[ItemsControl].((vm:CartViewModel)DataContext).DecreaseCommand}"
                                        CommandParameter="{Binding}">
                                    <Path Classes="icon sm" Data="{StaticResource IconMinus}"/>
                                </Button>
                                <TextBlock Text="{Binding Quantity}" MinWidth="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Classes="icon" Width="36" Height="36"
                                        Command="{Binding $parent[ItemsControl].((vm:CartViewModel)DataContext).IncreaseCommand}"
                                        CommandParameter="{Binding}">
                                    <Path Classes="icon sm" Data="{StaticResource IconPlus}"/>
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding LineTotal, StringFormat='{}{0:0} ₴'}"
                                       FontWeight="SemiBold" MinWidth="100"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="20,0"/>

                            <Button Grid.Column="4" Classes="icon" Width="40" Height="40"
                                    Command="{Binding $parent[ItemsControl].((vm:CartViewModel)DataContext).RemoveCommand}"
                                    CommandParameter="{Binding}">
                                <Path Classes="icon" Data="{StaticResource IconClose}"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Total + checkout -->
        <Border Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusM}"
                Padding="26">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Classes="muted" Text="Разом до сплати"/>
                    <TextBlock Text="{Binding Total, StringFormat='{}{0:0} ₴'}"
                               FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="primary"
                        Content="Оформити замовлення"
                        Command="{Binding CheckoutCommand}"
                        VerticalAlignment="Center" FontSize="18"/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
