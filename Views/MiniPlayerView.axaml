<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             x:Class="MusicApp.Views.MiniPlayerView"
             x:DataType="vm:MiniPlayerViewModel"
             Height="72">

    <Grid ColumnDefinitions="*,2*,*" VerticalAlignment="Stretch">

        <!-- Left: cover + track info -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                    VerticalAlignment="Center" Margin="16,0">
            <Border Width="48" Height="48" CornerRadius="{StaticResource RadiusS}"
                    Background="#FF2A2A2A">
                <TextBlock Text="🎵" FontSize="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" Opacity="0.6"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="2" MaxWidth="220">
                <TextBlock Text="{Binding TrackTitle}" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding ArtistName}" Classes="muted"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </StackPanel>

        <!-- Center: controls + progress -->
        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Button Classes="ghost" Content="⏮" Width="32" Height="32" Padding="0"
                        Command="{Binding PreviousCommand}"/>
                <Button Classes="play-circle" Width="36" Height="36" CornerRadius="18"
                        FontSize="13" Content="▶"
                        Command="{Binding PlayPauseCommand}"/>
                <Button Classes="ghost" Content="⏭" Width="32" Height="32" Padding="0"
                        Command="{Binding NextCommand}"/>
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*,Auto" Width="500">
                <TextBlock Grid.Column="0" Text="{Binding PositionText}"
                           Classes="muted" FontSize="11" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ProgressBar Grid.Column="1" Height="3"
                             Value="{Binding Progress}" Maximum="100"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource DividerBrush}"/>
                <TextBlock Grid.Column="2" Text="{Binding DurationText}"
                           Classes="muted" FontSize="11" VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- Right: volume + buttons -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
            <TextBlock Text="🔊" Foreground="{StaticResource FgSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <Slider Width="100" Minimum="0" Maximum="1" Value="{Binding Volume}"/>
            <Button Classes="ghost" Content="⛶" Width="32" Height="32" Padding="0"
                    Command="{Binding ExpandCommand}"
                    ToolTip.Tip="Розгорнути плеєр"/>
            <Button Classes="ghost" Content="✕" Width="32" Height="32" Padding="0"
                    Command="{Binding CloseCommand}"
                    ToolTip.Tip="Сховати"/>
        </StackPanel>
    </Grid>
</UserControl>
