<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             x:Class="MusicApp.Views.MiniPlayerView"
             x:DataType="vm:MiniPlayerViewModel"
             Height="80">

    <!-- Fluent's Slider wraps its track in [SliderPreContentMargin, Auto,
         SliderPostContentMargin] rows with a 32px MinHeight. A shorter slider
         overflows that template asymmetrically and the track drifts below the
         control's centre (so it never lines up with its icon). Shrinking the
         template height and making both margins equal star rows recentres the
         track inside the control — applies to both sliders in this bar only. -->
    <UserControl.Resources>
        <x:Double x:Key="SliderHorizontalHeight">22</x:Double>
        <GridLength x:Key="SliderPreContentMargin">*</GridLength>
        <GridLength x:Key="SliderPostContentMargin">*</GridLength>
    </UserControl.Resources>

    <!-- Spotify-style bar: the centre column is a [transport ; seek] block that
         is vertically centred as a group (buttons above the midline, seek below),
         while the cover (left) and volume (right) are each centred on the bar. -->
    <Grid ColumnDefinitions="*,1.4*,*">

        <!-- Left: cover + track info. Grid (not StackPanel) so long titles
             truncate at the column edge instead of at an arbitrary 220px. -->
        <Grid Grid.Column="0" ColumnDefinitions="Auto,*"
              VerticalAlignment="Center" Margin="16,0">
            <Border Width="48" Height="48" CornerRadius="{StaticResource RadiusS}"
                    Background="{Binding CurrentAlbum, Converter={StaticResource AlbumToGradient}}"
                    ClipToBounds="True">
                <Grid>
                    <!-- Album-less playback (local file): show a glyph instead
                         of a bare grey square. -->
                    <Path Classes="icon" Data="{StaticResource IconHeadphones}"
                          Width="22" Height="22" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          IsVisible="{Binding CurrentAlbum, Converter={x:Static ObjectConverters.IsNull}}"/>
                    <TextBlock Text="{Binding CurrentAlbum.Title, Converter={StaticResource FirstChar}}"
                               FontSize="20" FontWeight="Bold" Opacity="0.45"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               IsVisible="{Binding CurrentAlbum.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                    <Image Source="{Binding CurrentAlbum.CoverPath, Converter={StaticResource CoverPathToImage}}"
                           Stretch="UniformToFill"/>
                </Grid>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" Margin="12,0,0,0">
                <TextBlock Text="{Binding TrackTitle}" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding ArtistName}" Classes="muted"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>

        <!-- Center: transport controls over the seek strip, centred as a block -->
        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center" Margin="24,0">
            <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                <Button Classes="icon" Width="28" Height="28" VerticalAlignment="Center"
                        Command="{Binding ToggleShuffleCommand}"
                        ToolTip.Tip="{Binding ShuffleTooltip}">
                    <Path Width="16" Height="16" Classes="icon"
                          Classes.accent="{Binding IsShuffleOn}"
                          Data="{StaticResource IconShuffle}"/>
                </Button>
                <Button Classes="icon" Width="32" Height="32"
                        Command="{Binding PreviousCommand}"
                        ToolTip.Tip="Попередній трек">
                    <Path Classes="icon" Data="{StaticResource IconSkipBack}"/>
                </Button>
                <Button Classes="play-circle" Width="40" Height="40" CornerRadius="20"
                        Command="{Binding PlayPauseCommand}"
                        ToolTip.Tip="Відтворити / пауза (Пробіл)">
                    <Panel>
                        <Path Data="{StaticResource IconPlay}" Fill="{StaticResource OnAccentBrush}" Stroke="Transparent"
                              Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              IsVisible="{Binding !IsPlaying}"/>
                        <!-- Width:Height matches the glyph's 12x16 bounds so Uniform
                             stretch fills it with no side padding — that padding was
                             rounding asymmetrically (left) under fractional/XWayland
                             scaling and dragging the bars off-centre. -->
                        <Path Data="{StaticResource IconPause}" Fill="{StaticResource OnAccentBrush}" Stroke="Transparent"
                              Width="12" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              IsVisible="{Binding IsPlaying}"/>
                    </Panel>
                </Button>
                <Button Classes="icon" Width="32" Height="32"
                        Command="{Binding NextCommand}"
                        ToolTip.Tip="Наступний трек">
                    <Path Classes="icon" Data="{StaticResource IconSkipForward}"/>
                </Button>
                <Button Classes="icon" Width="28" Height="28" VerticalAlignment="Center"
                        Command="{Binding CycleRepeatCommand}"
                        ToolTip.Tip="{Binding RepeatTooltip}">
                    <Path Width="16" Height="16" Classes="icon"
                          Classes.accent="{Binding RepeatMode, Converter={StaticResource RepeatModeNotOff}}"
                          Data="{Binding RepeatMode, Converter={StaticResource RepeatModeToIcon}}"/>
                </Button>
            </StackPanel>

            <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" MaxWidth="640">
                <TextBlock Grid.Column="0" Text="{Binding PositionText}"
                           Classes="muted" FontSize="11" MinWidth="36" TextAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Slider Grid.Column="1" Name="SeekSlider" VerticalAlignment="Center"
                        Minimum="0" Maximum="100"
                        Value="{Binding Progress}"
                        Foreground="{StaticResource AccentBrush}"
                        PointerPressed="OnSeekPointerPressed"
                        PointerCaptureLost="OnSeekPointerReleased"
                        PointerReleased="OnSeekPointerReleased"/>
                <TextBlock Grid.Column="2" Text="{Binding DurationText}"
                           Classes="muted" FontSize="11" MinWidth="36"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- Right: volume + window buttons, centred on the bar -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
            <!-- The volume glyph's geometry renders ~2px above its box centre;
                 nudge the panel down to match the row. -->
            <Button Classes="icon" Width="28" Height="28" VerticalAlignment="Center"
                    Command="{Binding ToggleMuteCommand}"
                    ToolTip.Tip="Вимкнути / увімкнути звук">
                <Panel Margin="0,2,0,0">
                    <Path Classes="icon" Data="{StaticResource IconVolume}"
                          Width="18" Height="18" Stretch="Uniform"
                          IsVisible="{Binding !IsMuted}"/>
                    <Path Classes="icon" Data="{StaticResource IconVolumeMuted}"
                          Width="18" Height="18" Stretch="Uniform"
                          IsVisible="{Binding IsMuted}"/>
                </Panel>
            </Button>
            <Slider Width="110" Minimum="0" Maximum="1" Value="{Binding Volume}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Гучність"/>
            <Button Classes="icon" Width="32" Height="32"
                    Command="{Binding ExpandCommand}"
                    ToolTip.Tip="Відкрити сторінку плеєра">
                <Path Classes="icon" Data="{StaticResource IconMaximize}"/>
            </Button>
            <Button Classes="icon" Width="32" Height="32"
                    Command="{Binding CloseCommand}"
                    ToolTip.Tip="Зупинити і сховати плеєр">
                <Path Classes="icon" Data="{StaticResource IconClose}"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
