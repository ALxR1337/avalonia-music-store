<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             x:Class="MusicApp.Views.MiniPlayerView"
             x:DataType="vm:MiniPlayerViewModel"
             Height="90">

    <Grid ColumnDefinitions="*,2*,*" VerticalAlignment="Stretch">

        <!-- Left: cover + track info -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14"
                    VerticalAlignment="Center" Margin="20,0">
            <Border Width="70" Height="70" CornerRadius="{StaticResource RadiusS}"
                    Background="{Binding CurrentAlbum, Converter={StaticResource AlbumToGradient}}"
                    ClipToBounds="True">
                <Grid>
                    <TextBlock Text="{Binding CurrentAlbum.Title, Converter={StaticResource FirstChar}}"
                               FontSize="28" FontWeight="Bold" Opacity="0.45"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               IsVisible="{Binding CurrentAlbum.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                    <Image Source="{Binding CurrentAlbum.CoverPath, Converter={StaticResource CoverPathToImage}}"
                           Stretch="UniformToFill"/>
                </Grid>
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="3" MaxWidth="276">
                <TextBlock Text="{Binding TrackTitle}" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding ArtistName}" Classes="muted"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </StackPanel>

        <!-- Center: controls + progress -->
        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Classes="icon" Width="40" Height="40"
                        Command="{Binding PreviousCommand}">
                    <Path Classes="icon" Data="{StaticResource IconSkipBack}"/>
                </Button>
                <Button Classes="play-circle" Width="46" Height="46" CornerRadius="23"
                        Command="{Binding PlayPauseCommand}">
                    <Path Data="{StaticResource IconPlay}" Fill="Black" Stroke="Transparent"
                          Width="18" Height="18" Stretch="Uniform"/>
                </Button>
                <Button Classes="icon" Width="40" Height="40"
                        Command="{Binding NextCommand}">
                    <Path Classes="icon" Data="{StaticResource IconSkipForward}"/>
                </Button>
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*,Auto" Width="626">
                <TextBlock Grid.Column="0" Text="{Binding PositionText}"
                           Classes="muted" FontSize="14" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Slider Grid.Column="1" Name="SeekSlider"
                        Minimum="0" Maximum="100"
                        Value="{Binding Progress}"
                        Foreground="{StaticResource AccentBrush}"
                        PointerPressed="OnSeekPointerPressed"
                        PointerCaptureLost="OnSeekPointerReleased"
                        PointerReleased="OnSeekPointerReleased"/>
                <TextBlock Grid.Column="2" Text="{Binding DurationText}"
                           Classes="muted" FontSize="14" VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- Right: volume + buttons -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
            <Path Classes="icon" Data="{StaticResource IconVolume}"
                  VerticalAlignment="Center"/>
            <Slider Width="126" Minimum="0" Maximum="1" Value="{Binding Volume}"/>
            <Button Classes="icon" Width="40" Height="40"
                    Command="{Binding ExpandCommand}">
                <Path Classes="icon" Data="{StaticResource IconMaximize}"/>
            </Button>
            <Button Classes="icon" Width="40" Height="40"
                    Command="{Binding CloseCommand}">
                <Path Classes="icon" Data="{StaticResource IconClose}"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
