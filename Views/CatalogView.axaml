<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             x:Class="MusicApp.Views.CatalogView"
             x:DataType="vm:CatalogViewModel">

    <StackPanel Margin="32,24,32,32" Spacing="32">

        <!-- Hero / greeting -->
        <StackPanel Spacing="6">
            <TextBlock Classes="tiny" Text="ВІТАЄМО"/>
            <TextBlock Classes="h1" Text="Музика, яка звучить наживо"/>
            <TextBlock Classes="muted"
                       Text="Сотні платівок і компакт-дисків — переслухайте перед покупкою"/>
        </StackPanel>

        <!-- Genres row -->
        <StackPanel Spacing="14">
            <TextBlock Classes="h2" Text="Перегляд за жанрами"/>
            <Grid Classes="scroll-row">
                <ScrollViewer x:Name="GenreScroller"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Genres}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:GenreTile">
                                <Button Classes="genre-tile"
                                        Width="200" Margin="0,0,18,0"
                                        Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).OpenGenreCommand}"
                                        CommandParameter="{Binding Genre}">
                                    <Border Classes="genre-card"
                                            Width="200" Height="200"
                                            CornerRadius="{StaticResource RadiusM}"
                                            Background="{Binding Genre, Converter={StaticResource GenreToBrush}}"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="{Binding Name, Converter={StaticResource FirstChar}}"
                                                       FontSize="90" FontWeight="Bold" Opacity="0.5"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource FgPrimaryBrush}"
                                                       IsVisible="{Binding !HasCover}"/>
                                            <Image Source="{Binding CoverPath, Converter={StaticResource CoverPathToImage}}"
                                                   IsVisible="{Binding HasCover}"
                                                   Stretch="UniformToFill"/>

                                            <Path Fill="{Binding Genre, Converter={StaticResource GenreToBrush}, ConverterParameter=accent}"
                                                  Stretch="None"
                                                  Data="M 0,200 L 176,200 L 0,88 Z"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Bottom"/>

                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold" FontSize="20"
                                                       Foreground="White"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Bottom"
                                                       Margin="16,0,0,14"/>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Edge fade vignettes: row visually dissolves into BgBase when there's more to scroll -->
                <Border x:Name="GenreFadeLeft"
                        Classes="scroll-fade"
                        Width="120" Height="200"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                            <GradientStop Offset="0" Color="#FF121212"/>
                            <GradientStop Offset="1" Color="#00121212"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border x:Name="GenreFadeRight"
                        Classes="scroll-fade"
                        Width="120" Height="200"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                            <GradientStop Offset="0" Color="#00121212"/>
                            <GradientStop Offset="1" Color="#FF121212"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Button x:Name="GenreScrollLeft"
                        Classes="scroll-nav"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="-10,74,0,0"
                        Click="OnGenreScrollLeft">
                    <Border Classes="scroll-nav-circle">
                        <Path Data="{StaticResource IconChevronLeft}"
                              Stroke="{StaticResource FgPrimaryBrush}"
                              StrokeThickness="2.5"
                              StrokeLineCap="Round" StrokeJoin="Round"
                              Width="28" Height="28" Stretch="Uniform"
                              Fill="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="0,0,2,0"/>
                    </Border>
                </Button>
                <Button x:Name="GenreScrollRight"
                        Classes="scroll-nav"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,74,-10,0"
                        Click="OnGenreScrollRight">
                    <Border Classes="scroll-nav-circle">
                        <Path Data="{StaticResource IconChevronRight}"
                              Stroke="{StaticResource FgPrimaryBrush}"
                              StrokeThickness="2.5"
                              StrokeLineCap="Round" StrokeJoin="Round"
                              Width="28" Height="28" Stretch="Uniform"
                              Fill="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="2,0,0,0"/>
                    </Border>
                </Button>
            </Grid>
        </StackPanel>

        <!-- New arrivals -->
        <StackPanel Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="h2" Text="Нові надходження"/>
                <TextBlock Grid.Column="1" Classes="muted" Text="Показати всі"
                           VerticalAlignment="Bottom"/>
            </Grid>
            <ItemsControl ItemsSource="{Binding NewArrivals}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:NewArrivalAlbum">
                        <Border Classes="card" Width="250" Margin="0,0,18,18">
                            <Border.ContextFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="Додати LP в кошик"
                                              IsVisible="{Binding HasVinyl}"
                                              Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).AddToCartCommand}"
                                              CommandParameter="{Binding Vinyl}"/>
                                    <MenuItem Header="Додати CD в кошик"
                                              IsVisible="{Binding HasCd}"
                                              Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).AddToCartCommand}"
                                              CommandParameter="{Binding Cd}"/>
                                    <MenuItem Header="Прослухати семпл"
                                              Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).QuickPreviewCommand}"
                                              CommandParameter="{Binding PrimaryProduct}"/>
                                </MenuFlyout>
                            </Border.ContextFlyout>
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Border Width="215" Height="215"
                                            CornerRadius="{StaticResource RadiusM}"
                                            Background="{Binding Album, Converter={StaticResource AlbumToGradient}}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="{Binding Album.Title, Converter={StaticResource FirstChar}}"
                                                       FontSize="80" FontWeight="Bold" Opacity="0.45"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource FgPrimaryBrush}"
                                                       IsVisible="{Binding Album.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                            <Image Source="{Binding Album.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                                   Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>
                                    <Button Classes="play-circle"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,8,8"
                                            Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).QuickPreviewCommand}"
                                            CommandParameter="{Binding PrimaryProduct}">
                                        <Path Data="{StaticResource IconPlay}" Fill="Black" Stroke="Transparent"
                                              Width="22" Height="22" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                                <Button Classes="text-link"
                                        Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).OpenProductCommand}"
                                        CommandParameter="{Binding PrimaryProduct}">
                                    <StackPanel Spacing="3">
                                        <TextBlock Classes="title"
                                                   Text="{Binding Album.Title}"
                                                   FontWeight="SemiBold" FontSize="18"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Classes="subtitle muted"
                                                   Text="{Binding Album.Artist.Name}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel Spacing="6">
                                    <Button Classes="ghost"
                                            Padding="8,6" HorizontalContentAlignment="Stretch"
                                            HorizontalAlignment="Stretch"
                                            IsVisible="{Binding HasVinyl}"
                                            Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).OpenProductCommand}"
                                            CommandParameter="{Binding Vinyl}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Grid.Column="0" Classes="chip" Padding="8,2"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="LP" FontSize="14"
                                                           Foreground="{StaticResource FgSecondaryBrush}"/>
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Vinyl.Price, StringFormat='{}{0:0} ₴'}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                    <Button Classes="ghost"
                                            Padding="8,6" HorizontalContentAlignment="Stretch"
                                            HorizontalAlignment="Stretch"
                                            IsVisible="{Binding HasCd}"
                                            Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).OpenProductCommand}"
                                            CommandParameter="{Binding Cd}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Grid.Column="0" Classes="chip" Padding="8,2"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="CD" FontSize="14"
                                                           Foreground="{StaticResource FgSecondaryBrush}"/>
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Cd.Price, StringFormat='{}{0:0} ₴'}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Popular this month -->
        <StackPanel Spacing="14">
            <TextBlock Classes="h2" Text="Популярні цього місяця"/>
            <ItemsControl ItemsSource="{Binding Popular}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:Product">
                        <Border Classes="card" Width="238" Margin="0,0,18,18">
                            <StackPanel Spacing="12">
                                <Border Width="202" Height="202"
                                        CornerRadius="{StaticResource RadiusM}"
                                        Background="{Binding Album, Converter={StaticResource AlbumToGradient}}"
                                        ClipToBounds="True">
                                    <Grid>
                                        <TextBlock Text="{Binding Album.Title, Converter={StaticResource FirstChar}}"
                                                   FontSize="76" FontWeight="Bold" Opacity="0.45"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource FgPrimaryBrush}"
                                                   IsVisible="{Binding Album.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                        <Image Source="{Binding Album.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                               Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>
                                <Button Classes="text-link"
                                        Command="{Binding $parent[ItemsControl].((vm:CatalogViewModel)DataContext).OpenProductCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Spacing="3">
                                        <TextBlock Classes="title"
                                                   Text="{Binding Album.Title}"
                                                   FontWeight="SemiBold" FontSize="18"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Classes="subtitle muted"
                                                   Text="{Binding Album.Artist.Name}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Classes="icon sm filled" Data="{StaticResource IconStar}"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Rating, StringFormat='{}{0:0.0}'}"
                                               Classes="muted" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </StackPanel>
</UserControl>
