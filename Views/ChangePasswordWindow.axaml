<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MusicApp.ViewModels"
        x:Class="MusicApp.Views.ChangePasswordWindow"
        x:DataType="vm:ChangePasswordViewModel"
        Title="Зміна пароля"
        Width="420" Height="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBaseBrush}">

    <Border Padding="24" Background="{StaticResource BgBaseBrush}">
        <StackPanel Spacing="14">
            <TextBlock Classes="h2" Text="Зміна пароля"/>

            <StackPanel Spacing="4">
                <TextBlock Classes="muted" FontSize="12" Text="Поточний пароль"/>
                <TextBox Text="{Binding OldPassword}" PasswordChar="•"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Classes="muted" FontSize="12" Text="Новий пароль"/>
                <TextBox Text="{Binding NewPassword}" PasswordChar="•"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Classes="muted" FontSize="12" Text="Підтвердьте новий пароль"/>
                <TextBox Text="{Binding ConfirmPassword}" PasswordChar="•"/>
            </StackPanel>

            <TextBlock Foreground="#E07B5B"
                       Text="{Binding Error}"
                       IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Classes="link-inline" Content="Скасувати" Command="{Binding CancelCommand}"/>
                <Button Classes="primary" Content="Змінити" Command="{Binding SubmitCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
