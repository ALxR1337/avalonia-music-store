<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             x:Class="MusicApp.Views.PlayerView"
             x:DataType="vm:PlayerViewModel">

    <Grid ColumnDefinitions="280,*" Margin="0,0,0,0">

        <!-- Library sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                Padding="14,20" Margin="20,20,10,20"
                CornerRadius="{StaticResource RadiusM}">
            <StackPanel Spacing="14">
                <TextBlock Classes="tiny" Text="КУПЛЕНІ АЛЬБОМИ"/>
                <ItemsControl ItemsSource="{Binding PurchasedAlbums}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="m:Album">
                            <Button Classes="nav-item"
                                    Command="{Binding $parent[ItemsControl].((vm:PlayerViewModel)DataContext).PlayAlbumCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="36" Height="36"
                                            CornerRadius="{StaticResource RadiusS}"
                                            Background="#FF2A2A2A">
                                        <TextBlock Text="💿" FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Opacity="0.6"/>
                                    </Border>
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Artist.Name}"
                                                   Classes="muted" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Rectangle Height="1" Fill="{StaticResource DividerSoftBrush}" Margin="0,10"/>

                <Button Classes="secondary" Content="+ Додати файли"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- Now playing -->
        <Border Grid.Column="1" Margin="10,20,20,20"
                CornerRadius="{StaticResource RadiusL}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#FF1F1F1F"/>
                    <GradientStop Offset="1" Color="#FF121212"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid RowDefinitions="*,Auto" Margin="40">
                <!-- Big cover + title -->
                <StackPanel Grid.Row="0" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="280" Height="280" CornerRadius="{StaticResource RadiusL}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                <GradientStop Offset="0" Color="#FF4A2D1E"/>
                                <GradientStop Offset="1" Color="#FF161616"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🎵" FontSize="96"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Opacity="0.3"/>
                    </Border>
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TrackTitle}" Classes="h2"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ArtistName}"
                                   Classes="muted" FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AlbumTitle}"
                                   Foreground="{StaticResource FgTertiaryBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Controls -->
                <StackPanel Grid.Row="1" Spacing="14" Margin="0,20,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding PositionText}"
                                   Classes="muted" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ProgressBar Grid.Column="1" Value="{Binding Progress}" Maximum="100"
                                     Height="4" Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource DividerBrush}"/>
                        <TextBlock Grid.Column="2" Text="{Binding DurationText}"
                                   Classes="muted" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                        <Button Classes="ghost" Content="⏮" FontSize="18" Width="40" Height="40"
                                Command="{Binding PreviousCommand}"/>
                        <Button Classes="play-circle" Width="56" Height="56" CornerRadius="28"
                                Content="▶"
                                Command="{Binding PlayPauseCommand}"/>
                        <Button Classes="ghost" Content="⏭" FontSize="18" Width="40" Height="40"
                                Command="{Binding NextCommand}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="Auto,200,*" HorizontalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="🔊" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{StaticResource FgSecondaryBrush}"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Volume}"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
