<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             x:Class="MusicApp.Views.PlayerView"
             x:DataType="vm:PlayerViewModel"
             Name="PlayerRoot">

    <Grid>

        <!-- Main content: single column spanning between the app sidebar and the
             right edge. The previous in-page "Куплені альбоми" sidebar was
             removed — the library lives entirely in the grid view now. -->
        <Grid Margin="20,20,20,20">
            <!-- Home: tile grid of purchased albums + "add" tile -->
            <ScrollViewer IsVisible="{Binding !HasSelectedAlbum}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20" Margin="32,24,32,24">
                    <TextBlock Classes="h2" Text="Ваша бібліотека"/>
                    <ItemsControl ItemsSource="{Binding PurchasedAlbums}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="180" ItemHeight="240"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="m:Album">
                                <Button Classes="ghost" Padding="8" Margin="0,0,12,12"
                                        Command="{Binding $parent[ItemsControl].((vm:PlayerViewModel)DataContext).OpenAlbumCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Spacing="10" Width="156">
                                        <Border Width="156" Height="156"
                                                CornerRadius="{StaticResource RadiusS}"
                                                Background="{Binding ., Converter={StaticResource AlbumToGradient}}"
                                                ClipToBounds="True"
                                                BoxShadow="0 6 18 0 #66000000">
                                            <Grid>
                                                <TextBlock Text="{Binding Title, Converter={StaticResource FirstChar}}"
                                                           FontSize="56" FontWeight="Bold" Opacity="0.45"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{StaticResource FgPrimaryBrush}"
                                                           IsVisible="{Binding CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                <Image Source="{Binding CoverPath, Converter={StaticResource CoverPathToImage}}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist.Name}" Classes="muted" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- "+ add" tile, same card footprint as albums -->
                    <Button Classes="ghost" Padding="8"
                            HorizontalAlignment="Left"
                            Command="{Binding AddLocalFilesCommand}">
                        <StackPanel Spacing="10" Width="156">
                            <Border Width="156" Height="156"
                                    CornerRadius="{StaticResource RadiusS}"
                                    Background="{StaticResource BgElevatedBrush}"
                                    BorderBrush="{StaticResource DividerSoftBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="+"
                                           FontSize="64" FontWeight="Light"
                                           Foreground="{StaticResource FgSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Додати файли / плейлист / папку"
                                       FontSize="12" Classes="muted"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Classes="muted"
                               Text="Поки немає куплених альбомів. Купіть щось у каталозі або додайте локальні файли."
                               TextWrapping="Wrap"
                               IsVisible="{Binding !HasPurchasedAlbums}"
                               MaxWidth="480"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Album context (scrollable) -->
            <ScrollViewer IsVisible="{Binding HasSelectedAlbum}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="28" Margin="32,24,32,24" MaxWidth="1100" HorizontalAlignment="Stretch">

                    <!-- ===== Header ===== -->
                    <Grid ColumnDefinitions="240,*">
                        <!-- Cover acts as a button → opens fullscreen overlay on the shell. -->
                        <Button Grid.Column="0" Width="240" Height="240"
                                Padding="0" Background="Transparent" BorderThickness="0"
                                Cursor="Hand"
                                CornerRadius="{StaticResource RadiusL}"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenCoverFullscreenCommand}"
                                CommandParameter="{Binding SelectedAlbum}"
                                ToolTip.Tip="Розгорнути обкладинку">
                            <Border CornerRadius="{StaticResource RadiusL}"
                                    ClipToBounds="True"
                                    Background="{Binding SelectedAlbum, Converter={StaticResource AlbumToGradient}}"
                                    BoxShadow="0 12 32 0 #66000000">
                                <Grid>
                                    <TextBlock Text="{Binding HeaderTitle, Converter={StaticResource FirstChar}}"
                                               FontSize="86" FontWeight="Bold" Opacity="0.45"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource FgPrimaryBrush}"
                                               IsVisible="{Binding SelectedAlbum.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                    <Image Source="{Binding SelectedAlbum.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                           Stretch="UniformToFill"/>
                                </Grid>
                            </Border>
                        </Button>

                        <StackPanel Grid.Column="1" Spacing="10"
                                    VerticalAlignment="Center"
                                    Margin="28,0,0,0">
                            <TextBlock Classes="tiny" Text="АЛЬБОМ"/>

                            <!-- Album title: linked to the album's catalog product when one exists,
                                 otherwise rendered as plain text. -->
                            <Button Classes="text-link" HorizontalAlignment="Left"
                                    Command="{Binding GoToAlbumProductCommand}"
                                    IsVisible="{Binding HasAlbumProduct}"
                                    ToolTip.Tip="Відкрити в каталозі">
                                <TextBlock Text="{Binding HeaderTitle}" Classes="h1" TextWrapping="Wrap"/>
                            </Button>
                            <TextBlock Classes="h1" Text="{Binding HeaderTitle}" TextWrapping="Wrap"
                                       IsVisible="{Binding !HasAlbumProduct}"/>

                            <Button Classes="text-link" Padding="0" HorizontalAlignment="Left"
                                    Command="{Binding GoToArtistCommand}"
                                    IsVisible="{Binding HasArtist}"
                                    ToolTip.Tip="Усі альбоми артиста">
                                <TextBlock Text="{Binding ArtistName}" Classes="h3"
                                           Foreground="{StaticResource FgSecondaryBrush}"/>
                            </Button>

                            <!-- Metadata row: year · GENRE-LINK · trackcount · duration -->
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                <TextBlock Text="{Binding AlbumYear}" Classes="muted"
                                           IsVisible="{Binding HasYear}"/>
                                <TextBlock Text="·" Classes="muted"
                                           IsVisible="{Binding ShowYearSeparator}"/>
                                <Button Classes="text-link"
                                        Command="{Binding GoToGenreCommand}"
                                        IsVisible="{Binding HasGenre}"
                                        ToolTip.Tip="Каталог за жанром">
                                    <TextBlock Text="{Binding AlbumGenre}" Classes="muted"/>
                                </Button>
                                <TextBlock Text="·" Classes="muted"
                                           IsVisible="{Binding ShowGenreSeparator}"/>
                                <TextBlock Text="{Binding AlbumTrackCount}" Classes="muted"
                                           IsVisible="{Binding HasTrackCount}"/>
                                <TextBlock Text="·" Classes="muted"
                                           IsVisible="{Binding ShowTrackCountSeparator}"/>
                                <TextBlock Text="{Binding AlbumTotalDuration}" Classes="muted"
                                           IsVisible="{Binding HasTotalDuration}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                                <Button Classes="play-circle" Width="48" Height="48" CornerRadius="24"
                                        Command="{Binding PlaySelectedAlbumCommand}"
                                        ToolTip.Tip="Слухати альбом">
                                    <Path Data="{StaticResource IconPlay}" Fill="{StaticResource OnAccentBrush}" Stroke="Transparent"
                                          Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                                <Button Classes="icon" Width="40" Height="40"
                                        Command="{Binding ToggleShuffleCommand}"
                                        ToolTip.Tip="Перемішати">
                                    <Path Width="20" Height="20"
                                          Classes="icon"
                                          Classes.accent="{Binding IsShuffleOn}"
                                          Data="{StaticResource IconShuffle}"/>
                                </Button>
                                <Button Classes="icon" Width="40" Height="40"
                                        Command="{Binding CycleRepeatCommand}"
                                        ToolTip.Tip="Повтор">
                                    <Path Width="20" Height="20"
                                          Classes="icon"
                                          Classes.accent="{Binding RepeatMode, Converter={StaticResource RepeatModeNotOff}}"
                                          Data="{Binding RepeatMode, Converter={StaticResource RepeatModeToIcon}}"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Description -->
                    <StackPanel IsVisible="{Binding HasDescription}" Spacing="6" MaxWidth="780" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding AlbumDescription}" TextWrapping="Wrap"
                                   MaxLines="3" Classes="muted"
                                   IsVisible="{Binding !IsDescriptionExpanded}"/>
                        <TextBlock Text="{Binding AlbumDescription}" TextWrapping="Wrap" Classes="muted"
                                   IsVisible="{Binding IsDescriptionExpanded}"/>
                        <Button Classes="text-link" Padding="0" HorizontalAlignment="Left"
                                Command="{Binding ToggleDescriptionCommand}">
                            <TextBlock Text="Показати повністю" IsVisible="{Binding !IsDescriptionExpanded}"/>
                        </Button>
                        <Button Classes="text-link" Padding="0" HorizontalAlignment="Left"
                                Command="{Binding ToggleDescriptionCommand}">
                            <TextBlock Text="Згорнути" IsVisible="{Binding IsDescriptionExpanded}"/>
                        </Button>
                    </StackPanel>

                    <!-- ===== Tracklist ===== -->
                    <StackPanel Spacing="10" IsVisible="{Binding HasSelectedAlbum}">
                        <TextBlock Text="Треки" Classes="h2"/>
                        <Border CornerRadius="{StaticResource RadiusM}"
                                Background="{StaticResource BgElevatedBrush}"
                                Padding="6">
                            <ItemsControl ItemsSource="{Binding Tracks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TrackRowViewModel">
                                        <Border CornerRadius="{StaticResource RadiusS}" Padding="6,4" Margin="0,1"
                                                Background="{Binding IsCurrent, Converter={StaticResource BoolToHighlightBrush}}">
                                            <Grid ColumnDefinitions="36,*,Auto,Auto">
                                                <Grid Grid.Column="0">
                                                    <TextBlock Text="{Binding Position}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Classes="muted"
                                                               IsVisible="{Binding !IsCurrent}"/>
                                                    <Path Classes="icon sm accent filled"
                                                          Data="{StaticResource IconCircleFilled}"
                                                          Width="10" Height="10"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsVisible="{Binding IsCurrent}"/>
                                                </Grid>
                                                <Button Grid.Column="1" Classes="ghost"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left" Padding="8,6"
                                                        Command="{Binding $parent[ItemsControl].((vm:PlayerViewModel)DataContext).PlayTrackCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="{Binding IsCurrent, Converter={StaticResource BoolToFontWeight}}"
                                                               Foreground="{Binding IsCurrent, Converter={StaticResource BoolToCurrentForeground}}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Button>
                                                <Button Grid.Column="2" Classes="icon" Width="32" Height="32"
                                                        Command="{Binding $parent[ItemsControl].((vm:PlayerViewModel)DataContext).ToggleTrackLikeCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Width="16" Height="16"
                                                          Classes="icon"
                                                          Classes.filled="{Binding IsLiked}"
                                                          Classes.accent="{Binding IsLiked}"
                                                          Data="{StaticResource IconHeart}"/>
                                                </Button>
                                                <TextBlock Grid.Column="3" Text="{Binding DurationDisplay}"
                                                           Classes="muted" VerticalAlignment="Center"
                                                           Margin="10,0,8,0" Width="42" TextAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- ===== More from artist ===== -->
                    <StackPanel Spacing="12" IsVisible="{Binding HasMoreFromArtist}">
                        <TextBlock Text="{Binding MoreFromArtistTitle}" Classes="h2"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding MoreFromArtist}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="14"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="m:Album">
                                        <Button Classes="ghost" Padding="6"
                                                Command="{Binding $parent[ItemsControl].((vm:PlayerViewModel)DataContext).GoToArtistAlbumCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Width="140" Spacing="8">
                                                <Border Width="140" Height="140"
                                                        CornerRadius="{StaticResource RadiusS}"
                                                        Background="{Binding ., Converter={StaticResource AlbumToGradient}}"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <TextBlock Text="{Binding Title, Converter={StaticResource FirstChar}}"
                                                                   FontSize="42" FontWeight="Bold" Opacity="0.45"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource FgPrimaryBrush}"
                                                                   IsVisible="{Binding CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                        <Image Source="{Binding CoverPath, Converter={StaticResource CoverPathToImage}}"
                                                               Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Year}" FontSize="11" Classes="muted"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
