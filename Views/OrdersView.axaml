<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             x:Class="MusicApp.Views.OrdersView"
             x:DataType="vm:OrdersViewModel">

    <StackPanel Margin="32,24,32,32" Spacing="20">
        <TextBlock Classes="h1" Text="Замовлення"/>

        <Border Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusM}" Padding="16">
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="80,140,180,180,*"
                      Margin="6,0,6,8">
                    <TextBlock Grid.Column="0" Classes="tiny" Text="№"/>
                    <TextBlock Grid.Column="1" Classes="tiny" Text="ДАТА"/>
                    <TextBlock Grid.Column="2" Classes="tiny" Text="СТАТУС"/>
                    <TextBlock Grid.Column="3" Classes="tiny" Text="СУМА"/>
                    <TextBlock Grid.Column="4" Classes="tiny" Text="ПОЗИЦІЇ"/>
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Orders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="m:Order">
                            <Border Padding="6,12"
                                    BorderBrush="{StaticResource DividerSoftBrush}"
                                    BorderThickness="0,1,0,0">
                                <Grid ColumnDefinitions="80,140,180,180,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Id}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                               Classes="muted"/>
                                    <Border Grid.Column="2" Classes="chip" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Status}" FontSize="11"/>
                                    </Border>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding TotalAmount, StringFormat='{}{0:0} ₴'}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding Items.Count, StringFormat='{}{0} позицій'}"
                                               Classes="muted"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
