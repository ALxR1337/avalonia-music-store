<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             xmlns:s="using:MusicApp.Services.Search"
             xmlns:ctrl="using:MusicApp.Controls"
             xmlns:conv="using:Avalonia.Data.Converters"
             x:Class="MusicApp.Views.SearchResultsView"
             x:DataType="vm:SearchResultsViewModel">

    <Grid ColumnDefinitions="280,*" Margin="32,24,32,32">

        <!-- ============ Facet sidebar ============ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Margin="0,0,24,0">
            <StackPanel Spacing="22">
                <TextBlock Classes="h3" Text="Фільтри"/>

                <!-- Dynamic facets (genre/format/stock with live counts) -->
                <ItemsControl ItemsSource="{Binding Facets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:FacetGroupViewModel">
                            <StackPanel Spacing="6" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Title}" Classes="muted"/>
                                <ItemsControl ItemsSource="{Binding VisibleBuckets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="s:FacetBucket">
                                            <Button Classes="ghost" Padding="6,3"
                                                    HorizontalContentAlignment="Stretch"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding $parent[UserControl].((vm:SearchResultsViewModel)DataContext).ToggleFacetCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <CheckBox IsChecked="{Binding IsActive, Mode=OneWay}" IsHitTestVisible="False"/>
                                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count, StringFormat='({0})'}"
                                                               Classes="muted" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Long lists (artists) collapse to the first
                                     entries; the rest hide behind this toggle. -->
                                <Button Classes="link-inline" Margin="6,2,0,0"
                                        Content="{Binding ToggleLabel}"
                                        Command="{Binding ToggleExpandCommand}"
                                        IsVisible="{Binding HasMore}"/>

                                <!-- Any/All combiner sits right under the genre list and
                                     only appears once 2+ genres are picked. Unchecked =
                                     будь-який обраний жанр (OR); checked = усі разом (AND). -->
                                <CheckBox Margin="2,4,0,0"
                                          IsChecked="{Binding $parent[UserControl].((vm:SearchResultsViewModel)DataContext).GenresMatchAll}">
                                    <TextBlock Text="Лише з усіма обраними жанрами" TextWrapping="Wrap"/>
                                    <CheckBox.IsVisible>
                                        <MultiBinding Converter="{x:Static conv:BoolConverters.And}">
                                            <Binding Path="IsGenre"/>
                                            <Binding Path="$parent[UserControl].((vm:SearchResultsViewModel)DataContext).CanCombineGenres"/>
                                        </MultiBinding>
                                    </CheckBox.IsVisible>
                                </CheckBox>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Spacing="6">
                    <TextBlock Text="Рік" Classes="muted"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <NumericUpDown Grid.Column="0" Value="{Binding YearFrom}" Minimum="1900" Maximum="2100"
                                       PlaceholderText="від" ShowButtonSpinner="False"/>
                        <NumericUpDown Grid.Column="2" Value="{Binding YearTo}" Minimum="1900" Maximum="2100"
                                       PlaceholderText="до" ShowButtonSpinner="False"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Ціна, ₴" Classes="muted"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <NumericUpDown Grid.Column="0" Value="{Binding PriceFrom}" Minimum="0"
                                       PlaceholderText="від" ShowButtonSpinner="False"/>
                        <NumericUpDown Grid.Column="2" Value="{Binding PriceTo}" Minimum="0"
                                       PlaceholderText="до" ShowButtonSpinner="False"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Мінімальний рейтинг" Classes="muted"/>
                    <NumericUpDown Value="{Binding MinRating}" Minimum="0" Maximum="5" Increment="0.5"
                                   FormatString="0.0" ShowButtonSpinner="True"/>
                </StackPanel>

                <Button Classes="ghost" Content="Скинути все"
                        HorizontalAlignment="Stretch"
                        Command="{Binding ResetFiltersCommand}"/>
                <Button Classes="primary"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SaveQueryCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSave}" Fill="Transparent" Stroke="Black"
                              StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                              Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="Зберегти запит" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- ============ Results ============ -->
        <StackPanel Grid.Column="1" Spacing="18">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Classes="muted"
                           Text="{Binding TotalCount, StringFormat='Знайдено альбомів: {0}'}"/>
                <TextBlock Classes="h1" Text="{Binding HeaderLabel}"/>
            </StackPanel>

            <!-- Did-you-mean hint -->
            <Border CornerRadius="{StaticResource RadiusS}" Padding="12,8"
                    Background="{StaticResource BgElevatedBrush}"
                    IsVisible="{Binding HasDidYouMean}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Чи мали ви на увазі:" Classes="muted" VerticalAlignment="Center"/>
                    <Button Classes="ghost"
                            Command="{Binding ApplyDidYouMeanCommand}">
                        <TextBlock Text="{Binding DidYouMean}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Active filter chips (click to remove) -->
            <ItemsControl ItemsSource="{Binding ActiveFilterChips}"
                          IsVisible="{Binding ActiveFilterChips.Count}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ActiveFilterChip">
                        <Button Classes="chip-tab" Margin="0,0,6,6"
                                Command="{Binding $parent[UserControl].((vm:SearchResultsViewModel)DataContext).RemoveFilterCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                <Path Classes="icon sm" Data="{StaticResource IconClose}"
                                      VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Top result -->
            <Border Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusM}" Padding="16"
                    IsVisible="{Binding HasTopResult}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- The album's own cover sells the hit better than a
                         generic star; the star stays as a no-cover fallback. -->
                    <Border Grid.Column="0" Width="56" Height="56"
                            CornerRadius="{StaticResource RadiusS}"
                            Background="{StaticResource AccentBrush}"
                            ClipToBounds="True">
                        <Grid>
                            <Path Data="{StaticResource IconStar}" Fill="{StaticResource OnAccentBrush}" Stroke="Transparent"
                                  Width="28" Height="28" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image Source="{Binding TopResult.Album.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Classes="tiny" Text="ТОП-РЕЗУЛЬТАТ"/>
                        <TextBlock Text="{Binding TopResultLabel}" Classes="h3"/>
                        <TextBlock Text="{Binding TopResultSubLabel}" Classes="muted"
                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="primary" Content="Відкрити →"
                            Command="{Binding OpenTopResultCommand}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- No results -->
            <TextBlock Classes="muted"
                       Text="Нічого не знайдено. Спробуйте інші слова або скиньте фільтри."
                       IsVisible="{Binding HasNoResults}"/>

            <!-- Albums (the only result type — tracks/artists fold into the album) -->
            <ItemsControl ItemsSource="{Binding Albums}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- Stretches cards so each row fills the column —
                             a fixed-width WrapPanel left a gutter on the right. -->
                        <ctrl:UniformWrapPanel MinItemWidth="180" ColumnSpacing="12" RowSpacing="12"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="s:AlbumHit">
                        <Border Classes="card">
                            <Button Classes="ghost" Padding="0"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding $parent[ItemsControl].((vm:SearchResultsViewModel)DataContext).OpenAlbumCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Spacing="8">
                                    <ctrl:Square>
                                        <Border CornerRadius="{StaticResource RadiusM}"
                                                Background="{Binding Album, Converter={StaticResource AlbumToGradient}}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="{Binding Album.Title, Converter={StaticResource FirstChar}}"
                                                           FontSize="56" FontWeight="Bold" Opacity="0.45"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource FgPrimaryBrush}"
                                                           IsVisible="{Binding Album.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                <Image Source="{Binding Album.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </ctrl:Square>
                                    <TextBlock Text="{Binding Album.Title}"
                                               FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Album.Artist.Name}"
                                               Classes="muted"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:0} ₴'}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding FirstMatchedTrack.Title, StringFormat='↳ у треку «{0}»'}"
                                               IsVisible="{Binding HasMatchedTracks}"
                                               Foreground="{StaticResource FgTertiaryBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
