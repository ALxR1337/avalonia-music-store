<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             xmlns:s="using:MusicApp.Services.Search"
             x:Class="MusicApp.Views.SearchResultsView"
             x:DataType="vm:SearchResultsViewModel">

    <Grid ColumnDefinitions="350,*" Margin="32,24,32,32">

        <!-- ============ Facet sidebar ============ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Margin="0,0,30,0">
            <StackPanel Spacing="22">
                <TextBlock Classes="h3" Text="Фільтри"/>

                <!-- Dynamic facets (genre/format/stock with live counts) -->
                <ItemsControl ItemsSource="{Binding Facets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="s:FacetGroup">
                            <StackPanel Spacing="6" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Title}" Classes="muted"/>
                                <ItemsControl ItemsSource="{Binding Buckets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="s:FacetBucket">
                                            <Button Classes="ghost" Padding="6,3"
                                                    HorizontalContentAlignment="Stretch"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding $parent[UserControl].((vm:SearchResultsViewModel)DataContext).ToggleFacetCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <CheckBox IsChecked="{Binding IsActive, Mode=OneWay}" IsHitTestVisible="False"/>
                                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Count, StringFormat='({0})'}"
                                                               Classes="muted" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Spacing="6">
                    <TextBlock Text="Рік" Classes="muted"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <NumericUpDown Grid.Column="0" Value="{Binding YearFrom}" Minimum="1900" Maximum="2100"
                                       PlaceholderText="від" ShowButtonSpinner="False"/>
                        <NumericUpDown Grid.Column="2" Value="{Binding YearTo}" Minimum="1900" Maximum="2100"
                                       PlaceholderText="до" ShowButtonSpinner="False"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Ціна, ₴" Classes="muted"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <NumericUpDown Grid.Column="0" Value="{Binding PriceFrom}" Minimum="0"
                                       PlaceholderText="від" ShowButtonSpinner="False"/>
                        <NumericUpDown Grid.Column="2" Value="{Binding PriceTo}" Minimum="0"
                                       PlaceholderText="до" ShowButtonSpinner="False"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Мінімальний рейтинг" Classes="muted"/>
                    <NumericUpDown Value="{Binding MinRating}" Minimum="0" Maximum="5" Increment="0.5"
                                   FormatString="0.0" ShowButtonSpinner="True"/>
                </StackPanel>

                <Button Classes="ghost" Content="Скинути все"
                        HorizontalAlignment="Stretch"
                        Command="{Binding ResetFiltersCommand}"/>
                <Button Classes="primary"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SaveQueryCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSave}" Fill="Transparent" Stroke="Black"
                              StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                              Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                        <TextBlock Text="Зберегти запит" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- ============ Results ============ -->
        <StackPanel Grid.Column="1" Spacing="18">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Classes="muted"
                           Text="{Binding TotalCount, StringFormat='Знайдено {0} результатів'}"/>
                <TextBlock Classes="h1" Text="{Binding HeaderLabel}"/>
            </StackPanel>

            <!-- Did-you-mean hint -->
            <Border CornerRadius="{StaticResource RadiusS}" Padding="16,10"
                    Background="{StaticResource BgElevatedBrush}"
                    IsVisible="{Binding HasDidYouMean}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Чи мали ви на увазі:" Classes="muted" VerticalAlignment="Center"/>
                    <Button Classes="ghost"
                            Command="{Binding ApplyDidYouMeanCommand}">
                        <TextBlock Text="{Binding DidYouMean}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Chip-tabs -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="chip-tab" Classes.active="{Binding IsTabAll}"
                        Command="{Binding SelectTabCommand}" CommandParameter="All">
                    <TextBlock Text="{Binding TotalCount, StringFormat='Усі ({0})'}"/>
                </Button>
                <Button Classes="chip-tab" Classes.active="{Binding IsTabAlbums}"
                        IsEnabled="{Binding AlbumCount}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Albums">
                    <TextBlock Text="{Binding AlbumCount, StringFormat='Альбоми ({0})'}"/>
                </Button>
                <Button Classes="chip-tab" Classes.active="{Binding IsTabArtists}"
                        IsEnabled="{Binding ArtistCount}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Artists">
                    <TextBlock Text="{Binding ArtistCount, StringFormat='Виконавці ({0})'}"/>
                </Button>
                <Button Classes="chip-tab" Classes.active="{Binding IsTabTracks}"
                        IsEnabled="{Binding TrackCount}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Tracks">
                    <TextBlock Text="{Binding TrackCount, StringFormat='Треки ({0})'}"/>
                </Button>
                <Button Classes="chip-tab" Classes.active="{Binding IsTabReviews}"
                        IsEnabled="{Binding ReviewCount}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Reviews">
                    <TextBlock Text="{Binding ReviewCount, StringFormat='Відгуки ({0})'}"/>
                </Button>
            </StackPanel>

            <!-- Active filter chips (click to remove) -->
            <ItemsControl ItemsSource="{Binding ActiveFilterChips}"
                          IsVisible="{Binding ActiveFilterChips.Count}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ActiveFilterChip">
                        <Button Classes="chip-tab" Margin="0,0,6,6"
                                Command="{Binding $parent[UserControl].((vm:SearchResultsViewModel)DataContext).RemoveFilterCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                <Path Classes="icon sm" Data="{StaticResource IconClose}"
                                      VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Top result -->
            <Border Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusM}" Padding="20"
                    IsVisible="{Binding HasTopResult}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="70" Height="70"
                            CornerRadius="{StaticResource RadiusS}"
                            Background="{StaticResource AccentBrush}">
                        <Path Data="{StaticResource IconStar}" Fill="Black" Stroke="Transparent"
                              Width="36" Height="36" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="20,0" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Classes="tiny" Text="ТОП-РЕЗУЛЬТАТ"/>
                        <TextBlock Text="{Binding TopResultLabel}" Classes="h3"/>
                        <TextBlock Text="{Binding TopResultSubLabel}" Classes="muted"
                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="primary" Content="Відкрити →"
                            Command="{Binding OpenTopResultCommand}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- No results -->
            <TextBlock Classes="muted"
                       Text="Нічого не знайдено. Спробуйте інші слова або скиньте фільтри."
                       IsVisible="{Binding HasNoResults}"/>

            <!-- Albums -->
            <StackPanel Spacing="10" IsVisible="{Binding ShowAlbums}">
                <TextBlock Classes="h3" Text="Альбоми" IsVisible="{Binding Albums.Count}"/>
                <ItemsControl ItemsSource="{Binding Albums}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="s:ScoredAlbum">
                            <Border Classes="card" Width="226" Margin="0,0,16,16">
                                <Button Classes="ghost" Padding="0"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding $parent[ItemsControl].((vm:SearchResultsViewModel)DataContext).OpenAlbumProductCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Spacing="10">
                                        <Border CornerRadius="{StaticResource RadiusM}"
                                                Width="190" Height="190"
                                                Background="{Binding Album, Converter={StaticResource AlbumToGradient}}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="{Binding Album.Title, Converter={StaticResource FirstChar}}"
                                                           FontSize="70" FontWeight="Bold" Opacity="0.45"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource FgPrimaryBrush}"
                                                           IsVisible="{Binding Album.CoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                                <Image Source="{Binding Album.CoverPath, Converter={StaticResource CoverPathToImage}}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding Album.Title}"
                                                   FontWeight="SemiBold" FontSize="16"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Album.Artist.Name}"
                                                   Classes="muted"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Score, StringFormat='релевантність {0:0.000}'}"
                                                   Foreground="{StaticResource FgTertiaryBrush}"
                                                   FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Artists -->
            <StackPanel Spacing="10" IsVisible="{Binding ShowArtists}">
                <TextBlock Classes="h3" Text="Виконавці" IsVisible="{Binding Artists.Count}"/>
                <ItemsControl ItemsSource="{Binding Artists}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="s:ScoredArtist">
                            <Border Padding="14,8" Margin="0,0,0,6" CornerRadius="{StaticResource RadiusS}">
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <Border Width="46" Height="46" CornerRadius="23"
                                            Background="{StaticResource AccentBrush}"
                                            HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Artist.Name}" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Artist.Country}"
                                               Classes="muted" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Tracks -->
            <StackPanel Spacing="10" IsVisible="{Binding ShowTracks}">
                <TextBlock Classes="h3" Text="Треки" IsVisible="{Binding Tracks.Count}"/>
                <ItemsControl ItemsSource="{Binding Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="s:ScoredTrack">
                            <Border Padding="14,10" CornerRadius="{StaticResource RadiusS}">
                                <Grid ColumnDefinitions="46,*,Auto">
                                    <Button Grid.Column="0" Classes="icon" Width="36" Height="36"
                                            Command="{Binding $parent[ItemsControl].((vm:SearchResultsViewModel)DataContext).PlayTrackCommand}"
                                            CommandParameter="{Binding}">
                                        <Path Classes="icon sm filled primary"
                                              Data="{StaticResource IconPlay}"/>
                                    </Button>
                                    <TextBlock Grid.Column="1" Text="{Binding Track.Title}"
                                               VerticalAlignment="Center" Margin="10,0"/>
                                    <TextBlock Grid.Column="2" Classes="muted"
                                               Text="{Binding Track.DurationDisplay}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Reviews -->
            <StackPanel Spacing="10" IsVisible="{Binding ShowReviews}">
                <TextBlock Classes="h3" Text="Відгуки" IsVisible="{Binding Reviews.Count}"/>
                <ItemsControl ItemsSource="{Binding Reviews}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="s:ScoredReview">
                            <Border Padding="16" Margin="0,0,0,8"
                                    Background="{StaticResource BgElevatedBrush}"
                                    CornerRadius="{StaticResource RadiusS}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Review.UserDisplayName}"
                                               FontWeight="SemiBold" FontSize="16"/>
                                    <TextBlock Text="{Binding Review.Text}"
                                               TextWrapping="Wrap" Classes="muted"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
