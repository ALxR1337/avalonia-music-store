<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:m="using:MusicApp.Models"
             x:Class="MusicApp.Views.ProductView"
             x:DataType="vm:ProductViewModel">

    <StackPanel Margin="32,18,32,32" Spacing="20">

        <!-- Header / hero -->
        <Grid ColumnDefinitions="280,*" RowDefinitions="*">
            <Border Grid.Column="0" Width="240" Height="240"
                    CornerRadius="{StaticResource RadiusL}"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Offset="0" Color="#FF4A2D1E"/>
                        <GradientStop Offset="1" Color="#FF161616"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="{Binding AlbumTitle, Converter={StaticResource FirstChar}}"
                               FontSize="86" FontWeight="Bold" Opacity="0.45"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               IsVisible="{Binding !HasCover}"/>
                    <Image Source="{Binding CoverPath, Converter={StaticResource CoverPathToImage}}"
                           IsVisible="{Binding HasCover}"
                           Stretch="UniformToFill"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Classes="tiny" Text="АЛЬБОМ"/>
                <TextBlock Classes="h1" Text="{Binding AlbumTitle}"/>
                <TextBlock Text="{Binding ArtistName}"
                           Classes="h3"
                           Foreground="{StaticResource FgSecondaryBrush}"/>

                <TextBlock Classes="muted" Text="{Binding MetadataLine}"
                           Margin="0,8,0,0"/>

                <!-- Format toggle -->
                <StackPanel Orientation="Horizontal" Spacing="0" Margin="0,4,0,0">
                    <TextBlock Text="Формат:" VerticalAlignment="Center" Margin="0,0,10,0"
                               Classes="muted"/>
                    <Button Classes="chip-tab"
                            Command="{Binding SelectFormatCommand}"
                            CommandParameter="LP"
                            IsEnabled="{Binding HasVinyl}"
                            Classes.active="{Binding IsVinylSelected}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Classes="icon sm filled" Data="{StaticResource IconCircleFilled}"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Вініл LP" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="chip-tab"
                            Command="{Binding SelectFormatCommand}"
                            CommandParameter="CD"
                            IsEnabled="{Binding HasCd}"
                            Classes.active="{Binding IsCdSelected}"
                            Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Classes="icon sm" Data="{StaticResource IconCircle}"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="CD" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,12,0,0">
                    <TextBlock Text="{Binding PriceLabel}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{Binding StockLabel}" Classes="muted"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RatingLabel}" Classes="muted"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,16,0,0">
                    <Button Classes="primary"
                            Command="{Binding AddToCartCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Data="{StaticResource IconCart}" Fill="Transparent" Stroke="Black"
                                  StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                                  Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Додати в кошик" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="ghost"
                            Command="{Binding ToggleWishlistCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Classes="icon accent" Classes.filled="{Binding IsInWishlist}"
                                  Data="{StaticResource IconHeart}"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding WishlistLabel}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- About album -->
        <Border Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusM}" Padding="18"
                IsVisible="{Binding HasAlbumDescription}">
            <StackPanel Spacing="6">
                <TextBlock Classes="tiny" Text="ПРО АЛЬБОМ"/>
                <TextBlock Text="{Binding AlbumDescription}"
                           TextWrapping="Wrap" LineHeight="22"/>
            </StackPanel>
        </Border>

        <!-- About artist -->
        <Border Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusM}" Padding="18"
                IsVisible="{Binding HasArtistBio}">
            <StackPanel Spacing="6">
                <TextBlock Classes="tiny" Text="ПРО ВИКОНАВЦЯ"/>
                <TextBlock Text="{Binding ArtistName}" Classes="h3"/>
                <TextBlock Text="{Binding ArtistBio}"
                           TextWrapping="Wrap" LineHeight="22"/>
            </StackPanel>
        </Border>

        <!-- Tracklist -->
        <StackPanel Spacing="12">
            <TextBlock Classes="h2" Text="Треклист"/>
            <Border Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusM}"
                    Padding="6">
                <ItemsControl ItemsSource="{Binding Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="m:Track">
                            <Border Padding="10,8" CornerRadius="{StaticResource RadiusS}">
                                <Grid ColumnDefinitions="30,40,*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Position}"
                                               Classes="muted"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="icon" Width="28" Height="28"
                                            Command="{Binding $parent[ItemsControl].((vm:ProductViewModel)DataContext).PlaySampleCommand}"
                                            CommandParameter="{Binding}">
                                        <Path Classes="icon sm filled primary"
                                              Data="{StaticResource IconPlay}"/>
                                    </Button>
                                    <TextBlock Grid.Column="2" Text="{Binding Title}"
                                               VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="3" Classes="muted"
                                               Text="{Binding DurationDisplay}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>

        <!-- Reviews -->
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="h2"
                           Text="{Binding Reviews.Count, StringFormat='Відгуки ({0})'}"/>
                <Button Grid.Column="1" Classes="ghost"
                        Command="{Binding ToggleShowAllReviewsCommand}"
                        IsVisible="{Binding HasMoreReviews}">
                    <TextBlock Text="Показати всі"/>
                </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding Reviews}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:Review">
                        <Border Background="{StaticResource BgElevatedBrush}"
                                CornerRadius="{StaticResource RadiusM}"
                                Padding="14" Margin="0,0,0,10">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UserDisplayName}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Path Classes="icon sm accent filled" Data="{StaticResource IconStar}"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Rating}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                               Classes="muted"/>
                                </Grid>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Leave-review form (auth + purchase gated) -->
            <Border Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusM}"
                    Padding="14"
                    IsVisible="{Binding CanLeaveReview}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Залишити відгук" Classes="h3"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Оцінка:" Classes="muted" VerticalAlignment="Center"/>
                        <NumericUpDown Value="{Binding NewReviewRating}"
                                       Minimum="1" Maximum="5" Increment="1"
                                       Width="80" ShowButtonSpinner="True"/>
                        <Path Classes="icon accent filled" Data="{StaticResource IconStar}"
                              VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding NewReviewText}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             PlaceholderText="Ваші враження від альбому..."/>
                    <Button Classes="primary" Content="Надіслати"
                            HorizontalAlignment="Left"
                            Command="{Binding SubmitReviewCommand}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ReviewMessage}" Classes="muted"
                       IsVisible="{Binding ReviewMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

    </StackPanel>
</UserControl>
