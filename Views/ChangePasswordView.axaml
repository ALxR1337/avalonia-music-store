<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicApp.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520"
             x:Class="MusicApp.Views.ChangePasswordView"
             x:DataType="vm:ChangePasswordViewModel">

    <!-- MaxWidth: full-width password fields read as a broken layout on a
         1280px page; ~480px keeps label, field and buttons in one eye-span. -->
    <StackPanel Spacing="12" MaxWidth="480" HorizontalAlignment="Left">
        <TextBlock Classes="h3" Text="Зміна пароля"/>

        <StackPanel Spacing="4">
            <TextBlock Classes="muted" FontSize="12" Text="Поточний пароль"/>
            <TextBox x:Name="OldBox" Classes="revealPasswordButton"
                     Background="{StaticResource BgChipBrush}"
                     Text="{Binding OldPassword, UpdateSourceTrigger=PropertyChanged}"
                     PasswordChar="•" KeyDown="OnOldKeyDown"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Classes="muted" FontSize="12" Text="Новий пароль"/>
            <TextBox x:Name="NewBox" Classes="revealPasswordButton"
                     Background="{StaticResource BgChipBrush}"
                     Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                     PasswordChar="•" KeyDown="OnNewKeyDown"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Classes="muted" FontSize="12" Text="Підтвердьте новий пароль"/>
            <TextBox x:Name="ConfirmBox" Classes="revealPasswordButton"
                     Background="{StaticResource BgChipBrush}"
                     Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                     PasswordChar="•" KeyDown="OnConfirmKeyDown"/>
        </StackPanel>

        <TextBlock Foreground="{StaticResource DangerBrush}"
                   Text="{Binding Error}"
                   IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Classes="link-inline" Content="Скасувати" Command="{Binding CancelCommand}"/>
            <Button Classes="primary" Content="Змінити" Command="{Binding SubmitCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
